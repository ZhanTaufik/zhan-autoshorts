# ══════════════════════════════════════════════════════
#  YouTube Shorts Bot – Environment Variables
#  Copy this file to .env and fill in your values.
# ══════════════════════════════════════════════════════

# ── Reddit (required) ─────────────────────────────────
# Create an app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=YTShortsBot/1.0 by u/your_username

# ── Anthropic / Claude (required) ────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── TTS Engine ────────────────────────────────────────
# Options: "gtts" (free) | "openai" (better) | "elevenlabs" (best)
TTS_ENGINE=gtts

# OpenAI TTS (if TTS_ENGINE=openai)
OPENAI_API_KEY=sk-...
OPENAI_TTS_VOICE=onyx   # alloy | echo | fable | onyx | nova | shimmer

# ElevenLabs (if TTS_ENGINE=elevenlabs)
# ELEVENLABS_API_KEY=your_key_here
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Background video ──────────────────────────────────
# Option A: Point to a local MP4 file
# BACKGROUND_VIDEO=/path/to/your/background.mp4

# Option B: Auto-download from Pexels (free, no signup needed for basic use)
# Get a free key at https://www.pexels.com/api/
# PEXELS_API_KEY=your_pexels_key_here

# Option C: Drop MP4 files into the assets/ folder (auto-detected)

# ── Reddit content settings ───────────────────────────
SUBREDDITS=AskReddit,tifu,todayilearned,LifeProTips,NoStupidQuestions
MIN_SCORE=1000
FETCH_LIMIT=25

# ── YouTube ───────────────────────────────────────────
# Privacy: public | unlisted | private
YOUTUBE_PRIVACY=public
# Download client_secrets.json from Google Cloud Console
# https://console.cloud.google.com → YouTube Data API v3 → OAuth 2.0 Credentials

# ── Font for subtitles ────────────────────────────────
# Must be installed on your system. Common options:
# macOS: "Arial-Bold", "Helvetica-Bold", "Impact"
# Linux: "DejaVu-Sans-Bold", "Liberation-Sans-Bold"
# Windows: "Arial-Bold", "Impact"
SUBTITLE_FONT=Arial-Bold
